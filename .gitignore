.venv/
secrets.yaml
*.bin
__pycache__/
.DS_Store
# your own device configs (keep your name/key/secrets out of git)
my-*.yaml

# Generated by components/avatar/__init__.py to_code(): flat copies of the base/
# headers + animation module headers + the dispatch. Source-of-truth is __init__.py,
# avatar_select.h, avatar_number.h, avatar_color_output.h, avatar_render_state.{h,cpp},
# and the base/ + animations/ subdirs. The *.h glob matches only files directly in
# components/avatar/ (not subdirs), so base/ and animations/ stay tracked.
components/avatar/*.h
!components/avatar/avatar_select.h
!components/avatar/avatar_number.h
!components/avatar/avatar_color_output.h
!components/avatar/avatar_render_state.h
!components/avatar/avatar_render_state.cpp
components/avatar/__pycache__/
